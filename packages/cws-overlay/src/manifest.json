{
  "manifest_version": 3,
  "name": "Zovo — Extension Privacy Scanner",
  "description": "See privacy scores for Chrome extensions before you install. Know what your extensions can see.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://chromewebstore.google.com/*",
    "https://api.zovo.one/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://chromewebstore.google.com/detail/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
